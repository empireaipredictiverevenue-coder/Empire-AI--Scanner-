<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EMPIRE AI | HUD</title>
    <style>
        :root {
            --neon-blue: #0070f3;
            --neon-green: #00ff00;
            --bg-black: #050505;
            --card-gray: #111111;
        }

        body {
            background-color: var(--bg-black);
            color: white;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .header {
            width: 100%;
            max-width: 400px;
            margin-bottom: 30px;
        }

        h1 {
            font-size: 1.5rem;
            letter-spacing: 2px;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        .status-dot {
            height: 8px;
            width: 8px;
            background-color: var(--neon-green);
            border-radius: 50%;
            display: inline-block;
            margin-right: 5px;
            box-shadow: 0 0 10px var(--neon-green);
        }

        .btn-scan {
            width: 100%;
            max-width: 400px;
            background: var(--neon-blue);
            color: white;
            border: none;
            padding: 18px;
            border-radius: 12px;
            font-weight: bold;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px;
            cursor: pointer;
        }

        .card {
            width: 100%;
            max-width: 400px;
            background: var(--card-gray);
            border: 1px solid #333;
            border-radius: 16px;
            padding: 20px;
            box-sizing: border-box;
        }

        .btn-sync {
            width: 100%;
            background: var(--neon-green);
            color: black;
            border: none;
            padding: 15px;
            border-radius: 10px;
            font-weight: bold;
            margin-bottom: 20px;
            cursor: pointer;
        }

        .label {
            color: #666;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
        }

        .data-row {
            display: flex;
            justify-content: space-between;
            border-bottom: 1px solid #222;
            padding: 15px 0;
        }

        .lead-name {
            font-weight: bold;
            font-size: 1.1rem;
        }

        .status-text {
            color: var(--neon-blue);
            font-size: 0.8rem;
            font-weight: bold;
            animation: pulse 2s infinite;
        }

        .hook-box {
            margin-top: 15px;
            color: #ccc;
            line-height: 1.4;
            font-size: 0.95rem;
        }

        .wallet-tag {
            color: var(--neon-green);
            font-weight: bold;
        }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.4; }
            100% { opacity: 1; }
        }
    </style>
</head>
<body>

    <div class="header">
        <h1>EMPIRE AI</h1>
        <div><span class="status-dot"></span> PREDICTIVE REVENUE HUD</div>
    </div>

    <button class="btn-scan" onclick="alert('Scanning Miami Satellite Feed...')">Scan Miami Targets</button>

    <div class="card">
        <div class="label" style="color: var(--neon-green);">Live Lead Feed</div>
        <button class="btn-sync" onclick="fetchData()">Sync Revenue Data</button>

        <div id="lead-container">
            <div style="color: #444; text-align: center; padding: 20px;">
                Waiting for sync...
            </div>
        </div>
    </div>

    <script>
        async function fetchData() {
            const container = document.getElementById('lead-container');
            container.innerHTML = '<div style="color: #888; text-align: center; padding: 20px;">Accessing Satellite Data...</div>';
            
            try {
                // YOUR VERIFIED STEIN API URL
                const response = await fetch('https://api.steinhq.com/v1/storages/69dd55e63807a370b048991d/Leads');
                const data = await response.json();
                
                if (data.length > 0) {
                    container.innerHTML = '';
                    data.forEach(item => {
                        let displayHook = item.hook || "Waiting for hook generation...";
                        // Glow effect for your specific Solana trust tag
                        displayHook = displayHook.replace("ni57q", '<span class="wallet-tag">ni57q</span>');

                        container.innerHTML += `
                            <div class="data-row" style="flex-direction: column; border-bottom: 1px solid #222; padding-bottom: 15px; margin-bottom: 15px;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <div class="lead-name">${item.lead || 'Acquiring Lead Name...'}</div>
                                    <div class="status-text">TARGET ACQUIRED</div>
                                </div>
                                <div class="hook-box">${displayHook}</div>
                            </div>
                        `;
                    });
                } else {
                    container.innerHTML = '<div style="color: #666; text-align: center; padding: 20px;">Sheet is empty. Add a lead and a hook to Row 2.</div>';
                }
            } catch (error) {
                console.error(error);
                container.innerHTML = '<div style="color: red; text-align: center; padding: 20px;">Connection Error: Check Sheet Permissions</div>';
            }
        }
    </script>
</body>
</html>
