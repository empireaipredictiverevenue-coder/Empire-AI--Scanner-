<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Empire AI Scanner</title>
    <style>
        body { font-family: sans-serif; background: #111; color: white; padding: 20px; }
        .card { background: #222; padding: 20px; border-radius: 10px; margin-bottom: 20px; border: 1px solid #444; }
        button { background: #007bff; color: white; border: none; padding: 15px; width: 100%; border-radius: 5px; font-weight: bold; margin-top: 10px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 12px; }
        th, td { border: 1px solid #444; padding: 10px; text-align: left; }
        th { background: #333; }
    </style>
</head>
<body>

    <div class="card">
        <h1>empire-scanner</h1>
        <p>Satellite-grade lead scanning and predictive revenue engine.</p>
        <button onclick="alert('Scanning Miami...')">START MIAMI SCAN</button>
    </div>

    <div class="card">
        <h2>EMPIRE INTELLIGENCE HUD</h2>
        <button style="background: #28a745;" onclick="syncHUD()">SYNC LIVE LEADS</button>
        <div id="hud-data">
            <table>
                <thead>
                    <tr><th>Lead</th><th>Manus Hook</th></tr>
                </thead>
                <tbody id="lead-table">
                    <tr><td colspan="2" style="text-align:center;">Hit Sync to pull data...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        async function syncHUD() {
            const tableBody = document.getElementById('lead-table');
            tableBody.innerHTML = '<tr><td colspan="2">Loading...</td></tr>';
            try {
                // REPLACE THE URL BELOW WITH YOUR SHEETY LINK
                const response = await fetch('YOUR_SHEETY_URL_HERE');
                const data = await response.json();
                const leads = data.leads || data.sheet1; 
                
                tableBody.innerHTML = '';
                leads.slice(-5).reverse().forEach(lead => {
                    const row = `<tr>
                        <td><strong>${lead.company || 'New Lead'}</strong></td>
                        <td>${lead.hook || lead.strategy || 'Analyzing...'}</td>
                    </tr>`;
                    tableBody.innerHTML += row;
                });
            } catch (e) {
                tableBody.innerHTML = '<tr><td colspan="2">Error: Check Sheety URL</td></tr>';
            }
        }
    </script>
</body>
</html>
